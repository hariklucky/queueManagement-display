# 开启前端调试（保留 sourcemap、不压缩；配合 F12 打开 DevTools）
VITE_APP_DEBUG=true

# 生产环境 API 地址（打包前必改：桌面端无 Vite 代理，/api 会误请求到 index.html）
# 示例：VITE_API_BASE_URL=http://192.168.1.100:18084/api
VITE_API_BASE_URL=http://192.168.0.101:18084/api

# 终端设备编号（打包前必填）
VITE_GATEWAY_ID=Eq032511250004

# 读卡器、打印机本地服务地址
VITE_ID_CARD_READER_URL=http://192.168.0.101:18084/api/ReadCard
VITE_TICKET_PRINTER_URL=http://192.168.0.101:18084/api/PrintTicket
