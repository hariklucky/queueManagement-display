# 生产环境 API 地址（打包前必改：桌面端无 Vite 代理，/api 会误请求到 index.html）
# 示例：VITE_API_BASE_URL=http://192.168.1.100:18084/api
VITE_API_BASE_URL=http://192.168.1.100:18084/api

# 终端设备编号（打包前必填）
VITE_GATEWAY_ID=

# 读卡器、打印机本地服务地址
VITE_ID_CARD_READER_URL=http://127.0.0.1:8989/api/ReadCard
VITE_TICKET_PRINTER_URL=http://127.0.0.1:8990/api/PrintTicket
