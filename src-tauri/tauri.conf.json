{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "报到取号",
  "version": "0.1.0",
  "identifier": "com.qms.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:prod",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "报到取号",
        "width": 1280,
        "height": 1024,
        "minWidth": 1280,
        "minHeight": 1024,
        "resizable": true,
        "fullscreen": true,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https://cdn.bootcdn.net https://fonts.googleapis.com https://fonts.gstatic.com data: blob:; connect-src 'self' http: https: ipc: http://ipc.localhost; img-src 'self' data: blob: https:; style-src 'self' 'unsafe-inline' https://cdn.bootcdn.net https://fonts.googleapis.com; font-src 'self' https://cdn.bootcdn.net https://fonts.gstatic.com data:; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "shortDescription": "报到取号",
    "longDescription": "面向营业厅现场终端的桌面取号应用，支持预约取号与现场取号，集成身份证读卡与小票打印能力。",
    "publisher": "QMS",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "bundleName": "报到取号",
      "infoPlist": "./Info.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installerHooks": "windows/installer-hooks.nsh"
      },
      "wix": {
        "upgradeCode": "2e2fe057-a585-56a9-9dad-c127e14aacfe",
        "language": ["zh-CN"]
      }
    },
    "resources": {
      "../config.example.json": "config.example.json"
    }
  }
}
